{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "family-reminder-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-18",
  "workers_dev": true,
  "preview_urls": false,

  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/auth/*", "/logout", "/health", "/telegram/*", "/__scheduled"]
  },

  // One cron trigger is enough for all reminders.
  // The Worker checks D1 and decides which task instances need notifications.
  "triggers": {
    "crons": ["*/5 * * * *"]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "family-reminder-db",
      // Replace with the value returned by:
      // npx wrangler d1 create family-reminder-db
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],

  // Workers AI is used only by the optional Telegram text-to-task flow.
  "ai": {
    "binding": "AI"
  },

  // Non-secret defaults. Real secrets are configured with `wrangler secret put`.
  "vars": {
    "APP_LOCALE": "ru",
    "APP_TIMEZONE": "Europe/Kyiv",
    "ANNUAL_EVENT_NOTIFY_DAYS": "3,1,0",
    // Public Telegram bot username without @.
    "TELEGRAM_BOT_USERNAME": "your_bot_username",
    // Set to "true" to allow one-time task drafts from free-form Telegram text.
    "AI_TASK_CREATION_ENABLED": "false",
    "AI_TASK_CREATION_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  },

  "env": {
    "web-dev": {
      "name": "family-reminder-web-dev",
      "workers_dev": true,
      "preview_urls": false,

      // Do not run production reminder cron in the web development Worker.
      "triggers": {
        "crons": []
      },

      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "family-reminder-dev-db",
          // Replace with the value returned by:
          // npx wrangler d1 create family-reminder-dev-db
          "database_id": "11111111-1111-1111-1111-111111111111"
        }
      ],

      "vars": {
        "APP_LOCALE": "ru",
        "APP_TIMEZONE": "Europe/Kyiv",
        "ANNUAL_EVENT_NOTIFY_DAYS": "3,1,0",
        "TELEGRAM_BOT_USERNAME": "your_bot_username",
        "WEB_DEV_AUTH_ENABLED": "true"
      }
    },

    "web": {
      "name": "family-reminder-web",
      "workers_dev": true,
      "preview_urls": false,

      // Production web Worker must not run reminder cron.
      // The main bot Worker owns Telegram webhook, Cron and notifications.
      "triggers": {
        "crons": []
      },

      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "family-reminder-db",
          // Use the same production D1 database as the main bot Worker.
          "database_id": "00000000-0000-0000-0000-000000000000"
        }
      ],

      "vars": {
        "APP_LOCALE": "ru",
        "APP_TIMEZONE": "Europe/Kyiv",
        "ANNUAL_EVENT_NOTIFY_DAYS": "3,1,0",
        "TELEGRAM_BOT_USERNAME": "your_bot_username"
      }
    }
  }
}
