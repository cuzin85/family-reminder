{
  "name": "family-reminder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:web": "npm run web:build && wrangler deploy --env web",
    "deploy:web-dev": "npm run web:build && wrangler deploy --env web-dev",
    "typecheck": "tsc --noEmit && npm run typecheck:web",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "web:build": "vite build",
    "web:dev": "vite --host 0.0.0.0",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "d1:migrations:local": "wrangler d1 migrations apply family-reminder-db --local",
    "d1:migrations:remote": "wrangler d1 migrations apply family-reminder-db --remote",
    "d1:migrations:web:remote": "wrangler d1 migrations apply DB --env web --remote",
    "d1:migrations:web-dev:remote": "wrangler d1 migrations apply DB --env web-dev --remote",
    "d1:test:recurring:seed:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/recurring_seed.sql",
    "d1:test:recurring:inspect:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/recurring_inspect.sql",
    "d1:test:recurring:cleanup:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/recurring_cleanup.sql",
    "d1:test:monthly-daily:seed:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/monthly_daily_seed.sql",
    "d1:test:monthly-daily:inspect:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/monthly_daily_inspect.sql",
    "d1:test:monthly-daily:cleanup:local": "wrangler d1 execute family-reminder-db --local --file=./test-data/monthly_daily_cleanup.sql",
    "web:check-ui": "playwright test web-tests/visual-smoke.spec.ts",
    "web:screenshots": "playwright test web-tests/visual-screenshots.spec.ts",
    "web:check-ui:report": "playwright show-report ./tmp/playwright-report"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@playwright/test": "^1.57.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
