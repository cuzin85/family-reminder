# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Public Telegram bot username without @, used by the web login widget.
TELEGRAM_BOT_USERNAME=

# Random secret used to validate Telegram webhook requests.
TELEGRAM_WEBHOOK_SECRET=

# Random secret used to sign web session cookies.
WEB_SESSION_SECRET=

# Dev-only token for the optional /auth/dev flow.
WEB_DEV_AUTH_TOKEN=

# Comma-separated bootstrap admin Telegram user IDs.
ALLOWED_TELEGRAM_USER_IDS=

# Household timezone. Use an IANA timezone name.
APP_TIMEZONE=Europe/Kyiv

# Interface language. Supported values: ru, en.
APP_LOCALE=ru

# Annual event notification offsets in days before the event.
# Include 0 to notify on the event day.
ANNUAL_EVENT_NOTIFY_DAYS=3,1,0

# Optional Telegram text-to-task flow backed by Cloudflare Workers AI.
AI_TASK_CREATION_ENABLED=false
AI_TASK_CREATION_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Optional for non-interactive Wrangler deploys.
# Prefer Cloudflare Dashboard / CI / hosting provider secrets over local files.
CLOUDFLARE_API_TOKEN=
